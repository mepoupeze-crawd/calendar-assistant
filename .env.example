# Calendar Assistant Configuration

# LLM Provider (OpenAI)
OPENAI_API_KEY=sk-proj-xxxxx...

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi
ALLOWED_CHAT_ID=7131103597

# Google Calendar — OAuth2 (run: node scripts/authorize.mjs to fill these)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# The calendar to write events to (your Gmail address)
GOG_ACCOUNT=seu-email@gmail.com

# Your personal email — always added as attendee on every event
CALENDAR_OWNER_EMAIL=seu-email@gmail.com
